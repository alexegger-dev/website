# Optional: override public URLs at build time (e.g. GitHub Actions sets these for Pages).
# Never put API keys or private credentials here—this site is fully static.

# Canonical site origin (no trailing slash), e.g. https://youruser.github.io/your-repo
# NEXT_PUBLIC_SITE_URL=

# Subpath when using GitHub project Pages, e.g. /your-repo (omit for root or custom domain)
# NEXT_PUBLIC_BASE_PATH=
